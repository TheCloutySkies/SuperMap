PORT=3001
RAPIDAPI_KEY=
WINDY_API=

# Optional geocoding providers for /api/geocode fallback chain.
# The API will try Mapbox -> Geoapify -> Nominatim.
MAPBOX_TOKEN=
GEOAPIFY_KEY=

# Optional: Brave Search API for /api/search/searxng (recommended – free tier: brave.com/search/api)
# BRAVE_SEARCH_API_KEY=
# If unset, the API falls back to rotating public SearXNG instances (often rate-limited or down).

# Supabase forum backend
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Category request email notifications (optional)
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Admin approval endpoint token for POST /api/category-approve
FORUM_ADMIN_TOKEN=

# AI Threat Summary: use either Ollama (local/VPS) or Groq (e.g. Render).
# Groq (recommended on Render): free at https://console.groq.com — set GROQ_API_KEY; no Ollama needed.
# GROQ_API_KEY=
# GROQ_THREAT_MODEL=llama-3.1-8b-instant
# GROQ_THREAT_BACKUP_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_THREAT_TIMEOUT_MS=60000
# Rate-limit safeguards (app will not exceed these; set Groq UI limits ≥ these)
# GROQ_THREAT_MAX_CALLS_PER_24H=28
# GROQ_THREAT_MIN_INTERVAL_MS=3300000
# Ollama (local / your server): install from https://ollama.com, then ollama pull tinyllama:1.1b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_THREAT_MODEL=tinyllama:1.1b
# OLLAMA_THREAT_TIMEOUT_MS=90000

# Gas prices (/api/gas-prices): if EIA_API_KEY is set, EIA is used. If not set, GasBuddy GraphQL is used (no key).
# EIA setup (live US gas prices by state):
#   1. Go to https://www.eia.gov/opendata/register.php
#   2. Fill First Name, Last Name, Email (required).
#   3. Category: pick any, e.g. "Private citizen" or "Research/Consulting".
#   4. Reason: optional (e.g. "Gas price display in app").
#   5. Check "I agree to the terms", submit. Key is emailed immediately.
#   6. Add below: EIA_API_KEY=your_key_here then restart the API.
# EIA_API_KEY=
# Optional: default ZIP for GasBuddy when no state selected (default: 10001).
# GASBUDDY_DEFAULT_ZIP=10001

# Alpha Vantage for /api/stocks (homepage stock widget). Free key: alphavantage.co
# ALPHAVANTAGE_API_KEY=
