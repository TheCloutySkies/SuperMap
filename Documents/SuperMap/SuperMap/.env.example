# Optional: override Sentinel Hub instance ID for Sentinel-2 Burn Scars layer
# VITE_SENTINEL_INSTANCE_ID=your-instance-id

# API base URL for situational awareness backend (OSINT feeds, advanced search, news, etc.)
# When using "npm run dev" from repo root, the API runs on port 3001 automatically.
VITE_API_URL=http://localhost:3001

# Supabase (optional): login and saved articles. Create a project at supabase.com, then run
# the SQL in SuperMap/supabase/migrations/001_saved_articles.sql in the Supabase SQL editor.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
